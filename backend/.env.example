# Copy to backend/.env (git-ignored) — read by tajwid/config.py.
# Everything here is OPTIONAL: the service starts, and search works, without any of it.

# HyDE query expansion (GET /search?hyde=true). Any OpenAI-compatible provider.
# Without a key, HyDE degrades to the raw query and the response says hyde_used=false.
# GROQ_API_KEY and LLM_API_KEY are accepted as aliases for this same setting.
TAJWID_LLM_API_KEY=
TAJWID_LLM_BASE_URL=https://api.groq.com/openai/v1
TAJWID_LLM_MODEL_SMALL=openai/gpt-oss-20b

# Remote GPU inference (demo). Unset = local engines only; see REMOTE_GPU.md.
# The WebSocket endpoint of a Kaggle/Colab notebook running backend/remote_server.py,
# exposed through ngrok or a Cloudflare tunnel. Setting it ADDS a `remote` engine
# alongside the local ones; it does not replace them.
TAJWID_REMOTE_URL=
TAJWID_REMOTE_TIMEOUT_S=120

# Search defaults (overridable per request via ?mode=&hyde=&alpha=)
TAJWID_SEARCH_MODE=hybrid
TAJWID_SEARCH_HYDE=false
TAJWID_SEARCH_HYBRID_ALPHA=0.20
